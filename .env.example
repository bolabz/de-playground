# Copy to .env and adjust. .env is gitignored — never commit real secrets.
# Every value below is a LOCAL-ONLY placeholder for the dev rig.

# ---- Source: SQL Server / WideWorldImporters ----
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=WideWorldImporters
# Admin (sa) — used ONLY by the admin shell scripts (restore, enable-cdc, create-app-login).
MSSQL_SA_PASSWORD=Change_me_strong_passw0rd
# Least-privilege login the PIPELINE connects as (created by `make create-app-login`).
MSSQL_APP_USER=de_extract
MSSQL_APP_PASSWORD=Change_me_app_passw0rd

# ---- Lake: SeaweedFS (S3-compatible) ----
S3_ENDPOINT_URL=http://localhost:8333
# App identity (Read/Write/List, no Admin) — the pipeline uses these.
S3_ACCESS_KEY=appaccesskey
S3_SECRET_KEY=appsecretkey
# Admin identity — used ONLY by `make create-buckets`.
S3_ADMIN_ACCESS_KEY=adminaccesskey
S3_ADMIN_SECRET_KEY=adminsecretkey
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold

# ---- Processing: Spark ----
SPARK_MASTER_URL=spark://localhost:7077

# ---- Serving: Elasticsearch ----
ES_URL=http://localhost:9200
